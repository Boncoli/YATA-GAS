# --- Node.js ---
node_modules/
package-lock.json

# --- Environment variables and secrets (Security) ---
.env
credentials.json
server-properties.json

# --- Database (Data is backed up separately) ---
yata.db
*.db
*.db-shm
*.db-wal
*.db-journal

# --- Logs ---
*.log
logs/
npm-debug.log*

# --- OS & System generated files ---
.DS_Store
Thumbs.db
*.bak

# --- Frontend & Local Testing ---
# もしこれらの中身をGitに保存したい場合は行の頭に # をつけてください
public/
local_public/

# --- Python & Dashboard specific ---
# 自動生成される画像 (履歴管理不要)
*.png

# Pythonのキャッシュ
__pycache__/
*.py[cod]

# --- Fonts (Optional) ---
# リポジトリを軽量に保ちたい場合は、以下の # を外してください
*.ttf
*.otf
dashboard/fonts/